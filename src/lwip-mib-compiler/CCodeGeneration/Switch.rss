using System;
using System.Collections.Generic;

namespace CCodeGeneration
{
	public class matchCase : CodeContainerBase
	{
		public string Value { get; set; }

		public matchCase()
		{
		}

		public matchCase(string value)
		{
			this.Value = value;
		}

		public bool IsDefault
		{
			get { return (this.Value.ToLowerInvariant() == "default"); }
		}

		public static matchCase GenerateDefault()
		{
			return new matchCase("default");
		}

		public override void GenerateCode(level: i32, CGenerator generator)
		{
			if (!String.IsNullOrWhiteSpace(this.Value))
			{
				generator.IndentLine(level);
				if (this.IsDefault)
				{
					generator.OutputStream.Write("_ =>");
				}
				else
				{
					generator.OutputStream.Write(String.Format("case {0}:", this.Value));
				}
				generator.WriteNewLine();
				generator.IndentLine(level + 1);
				generator.OutputStream.Write("{");
				generator.WriteNewLine();

				base.GenerateCode(level + 1, generator);

				generator.IndentLine(level + 1);
				generator.OutputStream.Write("}");
				generator.WriteNewLine();

				generator.IndentLine(level + 1);
				generator.OutputStream.Write("break;");
				generator.WriteNewLine();
			}
		}
	}

	public class match: CodeElement
	{
		public string matchVar { get; set; }

		private List
	<matchCase>
		matches = new List
		<matchCase>
			();

		public match()
		{
		}

		public match(string matchVar)
		{
			this.matchVar = matchVar;
		}

		public List
			<matchCase> matches
		{
			get { return this.matches; }
		}

		public override void GenerateCode(level: i32, CGenerator generator)
		{
			if (!String.IsNullOrWhiteSpace(this.matchVar))
			{
				generator.IndentLine(level);
				generator.OutputStream.Write(String.Format("match ({0})", this.matchVar));
				generator.WriteNewLine();
				generator.IndentLine(level);
				generator.OutputStream.Write("{");
				generator.WriteNewLine();

				matchCase defaultCase = null; // generate 'default' always as last case
				foreach (matchCase matchCase in this.matches)
				{
					if (matchCase.IsDefault)
					{
						defaultCase = matchCase;
					}
					else
					{
						matchCase.GenerateCode(level + 1, generator);
					}
				}
				if (defaultCase != null)
				{
					defaultCase.GenerateCode(level + 1, generator);
				}

				generator.IndentLine(level);
				generator.OutputStream.Write("}");
				generator.WriteNewLine();
			}
		}
	}
}